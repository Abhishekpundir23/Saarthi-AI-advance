# --- TWILIO CONFIGURATION ---
# Get these from your Twilio Console
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Ensure this matches your Twilio WhatsApp Sandbox number, including the 'whatsapp:' prefix
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- GROQ (LLM & WHISPER) CONFIGURATION ---
# Get this from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# The model used for the CrewAI agents
GROQ_MODEL=llama3-70b-8192

# --- BUSINESS CONFIGURATION ---
BUSINESS_NAME="My Local Real Estate"
DEFAULT_REGION="Hinglish"
